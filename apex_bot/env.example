# ── APEX BOT — API KEYS ───────────────────────────────────────────────────────
# Copy this file to .env and fill in your real keys
# Get these from: OKX → Profile → API → Create API Key
# Permission needed: TRADE (for live mode) or READ-ONLY (for paper mode data)
#
# ⚠️  NEVER share this file or commit it to GitHub
# ⚠️  Keep PAPER_MODE = True in apex_bot.py until Stage 2 is done

OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Optional: Telegram alerts (get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
